---
import { useTranslations, type Locale } from '../i18n';
import { site } from '../data/site';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section class="hero" id="hero">
  <canvas id="neural-bg" aria-hidden="true"></canvas>
  <div class="container">
    <p class="availability">
      <span class="dot" aria-hidden="true"></span>
      <span class="dev-only" data-decrypt>{t.hero.availability}</span>
      <span class="mkt-only" data-decrypt>{t.hero.availabilityMkt}</span>
    </p>
    <h1 class="name">
      {t.hero.name.split(' ').map((word, i, words) => (
        <span class:list={['word', { accent: i > 0 }]}>
          {word}
          {i === words.length - 1 && <span class="cursor" aria-hidden="true"></span>}
        </span>
      ))}
    </h1>
    <div class="bottom">
      <div class="left">
        <p class="role">{t.hero.role}</p>
        <p class="intro">{t.hero.intro}</p>
      </div>
      <div class="right">
        <div class="actions">
          <a class="btn btn-solid" href="#work">{t.hero.ctaWork}</a>
          <a class="btn btn-ghost" href={site.cvPath} download>{t.hero.ctaCv}</a>
        </div>
        <p class="location">{t.hero.location}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: calc(100svh - 4.25rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-block: clamp(4rem, 10vw, 7rem) clamp(3rem, 6vw, 5rem);
    overflow: hidden;
  }

  #neural-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .hero > .container {
    position: relative;
    z-index: 1;
  }

  @media (prefers-reduced-motion: reduce), (max-width: 720px) {
    #neural-bg {
      display: none;
    }
  }

  .availability {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-bottom: clamp(1.5rem, 4vw, 2.5rem);
  }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse 2.4s ease infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.35;
    }
  }

  .name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(3.2rem, 11vw, 8.5rem);
    line-height: 0.95;
    letter-spacing: -0.045em;
    margin-bottom: clamp(2.5rem, 6vw, 4.5rem);
  }

  .word {
    display: block;
  }

  .word.accent {
    color: var(--accent);
  }

  .cursor {
    display: inline-block;
    width: 0.55em;
    height: 0.82em;
    margin-left: 0.12em;
    background: var(--accent);
    vertical-align: baseline;
    transform: translateY(0.08em);
    animation: blink 1.1s step-end infinite;
  }

  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  .bottom {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 2.5rem;
    border-top: 1px solid var(--line);
    padding-top: 2rem;
  }

  .role {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.9rem;
  }

  .intro {
    max-width: 26rem;
    color: var(--text-2);
    font-size: 1.02rem;
    line-height: 1.75;
  }

  .right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 1.1rem;
  }

  .actions {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .btn {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.8rem 1.7rem;
    border-radius: 999px;
    transition: transform 0.2s var(--ease), background-color 0.2s var(--ease),
      border-color 0.2s var(--ease), color 0.2s var(--ease);
  }

  .btn:hover {
    transform: translateY(-2px);
  }

  .btn-solid {
    background: var(--text);
    color: var(--bg);
  }

  .btn-solid:hover {
    background: var(--accent);
    color: var(--accent-ink);
  }

  .btn-ghost {
    border: 1px solid var(--line);
    color: var(--text);
  }

  .btn-ghost:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .location {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    color: var(--muted);
  }

  @media (max-width: 720px) {
    .bottom {
      flex-direction: column;
      align-items: flex-start;
    }
    .right {
      align-items: flex-start;
    }
  }
</style>

<script>
  const canvas = document.getElementById('neural-bg') as HTMLCanvasElement | null;
  const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

  // In narrow viewports the canvas is display:none via CSS; the
  // IntersectionObserver below keeps the loop idle while it's hidden.
  if (canvas && !reduced) {
    const ctx = canvas.getContext('2d')!;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const LINK_DIST = 150;
    const MOUSE_DIST = 220;
    const CANDLE_W = 16;
    const BODY_W = 9;
    const STEP_FRAMES = 40;

    let width = 0;
    let height = 0;
    let nodes: { x: number; y: number; vx: number; vy: number }[] = [];
    let candles: { o: number; h: number; l: number; c: number }[] = [];
    let frame = 0;
    let accent = '#4af0c4';
    let mode: 'neural' | 'market' =
      document.documentElement.dataset.theme === 'warm' ? 'market' : 'neural';
    let mouse: { x: number; y: number } | null = null;
    let running = true;
    let raf = 0;

    const css = (name: string) =>
      getComputedStyle(document.documentElement).getPropertyValue(name).trim();

    const readTheme = () => {
      accent = css('--accent');
      mode = document.documentElement.dataset.theme === 'warm' ? 'market' : 'neural';
    };
    readTheme();
    new MutationObserver(readTheme).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme'],
    });

    const initNeural = () => {
      const count = Math.min(110, Math.floor((width * height) / 16000));
      nodes = Array.from({ length: count }, () => ({
        x: Math.random() * width,
        y: Math.random() * height,
        vx: (Math.random() - 0.5) * 0.35,
        vy: (Math.random() - 0.5) * 0.35,
      }));
    };

    const candleCount = () => Math.ceil(width / CANDLE_W) + 1;

    const initMarket = () => {
      candles = [];
      let price = 100;
      for (let i = 0; i < candleCount(); i++) {
        const o = price;
        const c = o + (Math.random() - 0.48) * 3.2;
        candles.push({
          o,
          c,
          h: Math.max(o, c) + Math.random() * 1.4,
          l: Math.min(o, c) - Math.random() * 1.4,
        });
        price = c;
      }
    };

    const resize = () => {
      width = canvas.offsetWidth;
      height = canvas.offsetHeight;
      canvas.width = width * dpr;
      canvas.height = height * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      initNeural();
      initMarket();
    };
    resize();
    addEventListener('resize', resize);

    const hero = canvas.parentElement!;
    hero.addEventListener('mousemove', (e) => {
      const rect = canvas.getBoundingClientRect();
      mouse = { x: e.clientX - rect.left, y: e.clientY - rect.top };
    });
    hero.addEventListener('mouseleave', () => {
      mouse = null;
    });

    // Pause the simulation when the hero is off-screen
    new IntersectionObserver(
      ([entry]) => {
        running = entry.isIntersecting;
        if (running && !raf) raf = requestAnimationFrame(tick);
      },
      { threshold: 0 }
    ).observe(canvas);

    function drawNeural() {
      for (const n of nodes) {
        n.x += n.vx;
        n.y += n.vy;
        if (n.x < 0 || n.x > width) n.vx *= -1;
        if (n.y < 0 || n.y > height) n.vy *= -1;

        if (mouse) {
          const dx = mouse.x - n.x;
          const dy = mouse.y - n.y;
          const d = Math.hypot(dx, dy);
          if (d < MOUSE_DIST && d > 1) {
            n.x += (dx / d) * 0.25;
            n.y += (dy / d) * 0.25;
          }
        }
      }

      ctx.lineWidth = 1;
      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          const dx = nodes[i].x - nodes[j].x;
          const dy = nodes[i].y - nodes[j].y;
          const d = Math.hypot(dx, dy);
          if (d < LINK_DIST) {
            ctx.globalAlpha = (1 - d / LINK_DIST) * 0.14;
            ctx.strokeStyle = accent;
            ctx.beginPath();
            ctx.moveTo(nodes[i].x, nodes[i].y);
            ctx.lineTo(nodes[j].x, nodes[j].y);
            ctx.stroke();
          }
        }
        if (mouse) {
          const dx = nodes[i].x - mouse.x;
          const dy = nodes[i].y - mouse.y;
          const d = Math.hypot(dx, dy);
          if (d < MOUSE_DIST) {
            ctx.globalAlpha = (1 - d / MOUSE_DIST) * 0.22;
            ctx.strokeStyle = accent;
            ctx.beginPath();
            ctx.moveTo(nodes[i].x, nodes[i].y);
            ctx.lineTo(mouse.x, mouse.y);
            ctx.stroke();
          }
        }
      }

      ctx.globalAlpha = 0.5;
      ctx.fillStyle = accent;
      for (const n of nodes) {
        ctx.beginPath();
        ctx.arc(n.x, n.y, 1.4, 0, Math.PI * 2);
        ctx.fill();
      }
      ctx.globalAlpha = 1;
    }

    function drawMarket() {
      frame++;
      const up = css('--up');
      const down = css('--down');

      // The last candle keeps "trading"; a new one opens every STEP_FRAMES
      const cur = candles[candles.length - 1];
      cur.c += (Math.random() - 0.5) * 0.9;
      cur.h = Math.max(cur.h, cur.c);
      cur.l = Math.min(cur.l, cur.c);
      if (frame % STEP_FRAMES === 0) {
        candles.push({ o: cur.c, h: cur.c, l: cur.c, c: cur.c });
        while (candles.length > candleCount()) candles.shift();
      }

      let min = Infinity;
      let max = -Infinity;
      for (const k of candles) {
        if (k.l < min) min = k.l;
        if (k.h > max) max = k.h;
      }
      const pad = (max - min) * 0.25 || 1;
      const y = (v: number) => height - ((v - (min - pad)) / (max - min + pad * 2)) * height;
      const startX = width - candles.length * CANDLE_W;

      ctx.lineWidth = 1;
      for (let i = 0; i < candles.length; i++) {
        const k = candles[i];
        const x = startX + i * CANDLE_W + CANDLE_W / 2;
        const color = k.c >= k.o ? up : down;

        ctx.globalAlpha = 0.28;
        ctx.strokeStyle = color;
        ctx.beginPath();
        ctx.moveTo(x, y(k.h));
        ctx.lineTo(x, y(k.l));
        ctx.stroke();

        ctx.globalAlpha = 0.3;
        ctx.fillStyle = color;
        const top = y(Math.max(k.o, k.c));
        const bodyH = Math.max(1.5, Math.abs(y(k.o) - y(k.c)));
        ctx.fillRect(x - BODY_W / 2, top, BODY_W, bodyH);
      }

      // Trading-terminal crosshair following the cursor
      if (mouse) {
        ctx.globalAlpha = 0.3;
        ctx.strokeStyle = accent;
        ctx.setLineDash([5, 6]);
        ctx.beginPath();
        ctx.moveTo(0, mouse.y);
        ctx.lineTo(width, mouse.y);
        ctx.moveTo(mouse.x, 0);
        ctx.lineTo(mouse.x, height);
        ctx.stroke();
        ctx.setLineDash([]);
        ctx.globalAlpha = 0.6;
        ctx.fillStyle = accent;
        ctx.fillRect(mouse.x - 2.5, mouse.y - 2.5, 5, 5);
      }
      ctx.globalAlpha = 1;
    }

    function tick() {
      raf = 0;
      if (!running) return;
      ctx.clearRect(0, 0, width, height);
      if (mode === 'market') drawMarket();
      else drawNeural();
      raf = requestAnimationFrame(tick);
    }
    raf = requestAnimationFrame(tick);
  }
</script>
