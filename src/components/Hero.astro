---
import { useTranslations, type Locale } from '../i18n';
import { site } from '../data/site';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section class="hero">
  <div class="container">
    <p class="availability">
      <span class="dot" aria-hidden="true"></span>
      {t.hero.availability}
    </p>
    <h1 class="name">
      {t.hero.name.split(' ').map((word, i, words) => (
        <span class:list={['word', { accent: i > 0 }]}>
          {word}
          {i === words.length - 1 && <span class="cursor" aria-hidden="true"></span>}
        </span>
      ))}
    </h1>
    <div class="bottom">
      <div class="left">
        <p class="role">{t.hero.role}</p>
        <p class="intro">{t.hero.intro}</p>
      </div>
      <div class="right">
        <div class="actions">
          <a class="btn btn-solid" href="#work">{t.hero.ctaWork}</a>
          <a class="btn btn-ghost" href={site.cvPath} download>{t.hero.ctaCv}</a>
        </div>
        <p class="location">{t.hero.location}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: calc(100svh - 4.25rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-block: clamp(4rem, 10vw, 7rem) clamp(3rem, 6vw, 5rem);
  }

  .availability {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-bottom: clamp(1.5rem, 4vw, 2.5rem);
  }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse 2.4s ease infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.35;
    }
  }

  .name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(3.2rem, 11vw, 7.5rem);
    line-height: 0.95;
    letter-spacing: -0.045em;
    margin-bottom: clamp(2.5rem, 6vw, 4.5rem);
  }

  .word {
    display: block;
  }

  .word.accent {
    color: var(--accent);
  }

  .cursor {
    display: inline-block;
    width: 0.55em;
    height: 0.82em;
    margin-left: 0.12em;
    background: var(--accent);
    vertical-align: baseline;
    transform: translateY(0.08em);
    animation: blink 1.1s step-end infinite;
  }

  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  .bottom {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 2.5rem;
    border-top: 1px solid var(--line);
    padding-top: 2rem;
  }

  .role {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.9rem;
  }

  .intro {
    max-width: 26rem;
    color: var(--muted);
    font-size: 1.02rem;
    line-height: 1.75;
  }

  .right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 1.1rem;
  }

  .actions {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .btn {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.8rem 1.7rem;
    border-radius: 999px;
    transition: transform 0.2s var(--ease), background-color 0.2s var(--ease),
      border-color 0.2s var(--ease), color 0.2s var(--ease);
  }

  .btn:hover {
    transform: translateY(-2px);
  }

  .btn-solid {
    background: var(--text);
    color: var(--bg);
  }

  .btn-solid:hover {
    background: var(--accent);
    color: var(--accent-ink);
  }

  .btn-ghost {
    border: 1px solid var(--line);
    color: var(--text);
  }

  .btn-ghost:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .location {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    color: var(--muted);
  }

  @media (max-width: 720px) {
    .bottom {
      flex-direction: column;
      align-items: flex-start;
    }
    .right {
      align-items: flex-start;
    }
  }
</style>
