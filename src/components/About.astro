---
import { useTranslations, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section id="about" class="section">
  <div class="container grid">
    <div class="reveal">
      <p class="kicker">{t.about.kicker}</p>
      <h2 class="heading">{t.about.heading}</h2>
    </div>
    <div class="body reveal">
      {t.about.paragraphs.map((p) => <p class="para">{p}</p>)}
      <div class="lists">
        <div>
          <p class="list-label">{t.about.focusLabel}</p>
          <ul class="focus">
            {t.about.focus.map((f) => <li>{f}</li>)}
          </ul>
        </div>
        <div>
          <p class="list-label">{t.about.stackLabel}</p>
          <ul class="stack">
            {t.about.stack.map((s) => <li>{s}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: clamp(2.5rem, 6vw, 5rem);
    align-items: start;
  }

  .para {
    color: var(--muted);
    font-size: 1.02rem;
    line-height: 1.85;
    margin-bottom: 1.4rem;
  }

  .lists {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 2.5rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--line);
  }

  .list-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .focus {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    font-size: 0.95rem;
  }

  .stack {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .stack li {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.05em;
    color: var(--muted);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.3rem 0.75rem;
  }

  @media (max-width: 900px) {
    .grid,
    .lists {
      grid-template-columns: 1fr;
    }
  }
</style>
