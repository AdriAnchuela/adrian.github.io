---
---

<div class="status" aria-hidden="true">
  <div class="left">
    <span class="branch"><span class="glyph">⎇</span> main</span>
    <span class="path" id="status-path">portfolio/README.md</span>
  </div>
  <div class="right">
    <span class="dev-only">UTF-8</span>
    <span class="dev-only">TypeScript</span>
    <span class="mkt-only tick">$AA</span>
    <span class="mkt-only up">▲ 24/7</span>
    <span>Madrid, ES</span>
  </div>
</div>

<style>
  .status {
    display: none;
  }

  @media (min-width: 1100px) {
    .status {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 100;
      height: 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-inline: 1.4rem;
      background: color-mix(in srgb, var(--bg) 88%, transparent);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-top: 1px solid var(--line-soft);
      font-family: var(--font-mono);
      font-size: 0.62rem;
      letter-spacing: 0.08em;
      color: var(--muted);
    }
  }

  .left,
  .right {
    display: flex;
    align-items: center;
    gap: 1.4rem;
  }

  .branch {
    color: var(--accent);
  }

  .glyph {
    font-size: 0.72rem;
  }

  .tick {
    color: var(--text);
  }

  .up {
    color: var(--up);
  }
</style>

<script>
  // Scrollspy: highlight the current "file" in the explorer and status bar
  const files: Record<string, string> = {
    hero: 'portfolio/README.md',
    clients: 'portfolio/clients.log',
    about: 'portfolio/about.md',
    work: 'portfolio/projects/',
    markets: 'portfolio/markets.md',
    experience: 'portfolio/experience.md',
    education: 'portfolio/education.md',
    contact: 'portfolio/contact.sh',
  };

  const pathEl = document.getElementById('status-path');
  const links = [...document.querySelectorAll<HTMLElement>('[data-spy-link]')];
  const sections = Object.keys(files)
    .map((id) => document.getElementById(id))
    .filter((s): s is HTMLElement => !!s);

  const setActive = (id: string) => {
    if (pathEl) pathEl.textContent = files[id];
    links.forEach((l) => l.classList.toggle('active', l.dataset.spyLink === id));
  };

  const spy = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) setActive(entry.target.id);
      }
    },
    { rootMargin: '-40% 0px -55% 0px' }
  );
  sections.forEach((s) => spy.observe(s));
</script>
