---
import { useTranslations, type Locale } from '../i18n';
import { site } from '../data/site';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section id="contact" class="section">
  <div class="container">
    <p class="kicker reveal">{t.contact.kicker}</p>
    <h2 class="cta reveal" data-decrypt>{t.contact.heading}</h2>
    <p class="lead reveal">{t.contact.lead}</p>
    <a class="email reveal" href={`mailto:${site.email}`}>{site.email}</a>
    <div class="row reveal">
      <div class="cell">
        <p class="label">{t.contact.locationLabel}</p>
        <p class="value">{t.hero.location}</p>
      </div>
      <div class="cell">
        <p class="label">{t.contact.phoneLabel}</p>
        <p class="value"><a href={site.phoneHref}>{site.phone}</a></p>
      </div>
      <div class="cell">
        <p class="label">{t.contact.instagramLabel}</p>
        <p class="value">
          <a href={site.instagramUrl} target="_blank" rel="noopener noreferrer">
            {site.instagram}
          </a>
        </p>
      </div>
      <a class="cv" href={site.cvPath} download>
        <span aria-hidden="true">↓</span>
        {t.contact.cv}
      </a>
    </div>
  </div>
</section>

<style>
  .cta {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.8rem, 8vw, 6rem);
    line-height: 1;
    letter-spacing: -0.015em;
    margin-bottom: 1.5rem;
    text-wrap: balance;
  }

  .lead {
    max-width: 32rem;
    color: var(--muted);
    font-size: 1.02rem;
    line-height: 1.8;
    margin-bottom: 2.5rem;
  }

  .email {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: clamp(1.05rem, 3vw, 1.9rem);
    letter-spacing: -0.01em;
    color: var(--accent);
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 40%, transparent);
    padding-bottom: 0.2rem;
    margin-bottom: clamp(3rem, 7vw, 5rem);
    transition: border-color 0.2s var(--ease);
    overflow-wrap: anywhere;
  }

  .email:hover {
    border-color: var(--accent);
  }

  .row {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 2rem;
    border-top: 1px solid var(--line);
    padding-top: 2rem;
  }

  .label {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.4rem;
  }

  .value {
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }

  .value a:hover {
    color: var(--accent);
  }

  .cv {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.8rem 1.6rem;
    transition: border-color 0.2s var(--ease), color 0.2s var(--ease);
  }

  .cv:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
</style>
