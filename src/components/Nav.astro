---
import ThemeToggle from './ThemeToggle.astro';
import { useTranslations, localePath, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const otherLocale: Locale = locale === 'en' ? 'es' : 'en';

const links = [
  { href: '#about', label: t.nav.about },
  { href: '#work', label: t.nav.work },
  { href: '#experience', label: t.nav.experience },
  { href: '#contact', label: t.nav.contact },
];
---

<header class="nav">
  <div class="container nav-inner">
    <a class="logo" href={localePath(locale)}>
      adrian<em>.</em>anchuela
    </a>
    <nav class="links" aria-label="Main">
      {links.map((link) => <a href={link.href}>{link.label}</a>)}
    </nav>
    <div class="controls">
      <a
        class="lang"
        href={localePath(otherLocale)}
        aria-label={t.nav.switchLang}
        title={t.nav.switchLang}
      >
        {t.nav.switchLangShort}
      </a>
      <ThemeToggle label={t.nav.switchTheme} />
    </div>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--line-soft);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    height: 4.25rem;
  }

  .logo {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }

  .logo em {
    color: var(--accent);
    font-style: normal;
  }

  .links {
    display: flex;
    gap: 2.2rem;
  }

  .links a {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    transition: color 0.2s var(--ease);
  }

  .links a:hover {
    color: var(--text);
  }

  .controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .lang {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    color: var(--muted);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.42rem 0.85rem;
    transition: color 0.2s var(--ease), border-color 0.2s var(--ease);
  }

  .lang:hover {
    color: var(--text);
    border-color: var(--muted);
  }

  @media (max-width: 720px) {
    .links {
      display: none;
    }
  }
</style>
