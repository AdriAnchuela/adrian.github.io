---
interface Props {
  label: string;
}
const { label } = Astro.props;
---

<button class="theme-toggle" data-theme-toggle aria-label={label} title={label}>
  <span class="swatch swatch-warm" aria-hidden="true"></span>
  <span class="swatch swatch-dark" aria-hidden="true"></span>
</button>

<style>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.1rem;
    height: 2.1rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    transition: border-color 0.2s var(--ease);
  }

  .theme-toggle:hover {
    border-color: var(--muted);
  }

  .swatch {
    width: 0.8rem;
    height: 0.8rem;
    border-radius: 50%;
  }

  /* Show the accent of the theme you would switch to */
  .swatch-warm {
    background: #f0a84a;
  }
  .swatch-dark {
    background: #4af0c4;
  }
  :global([data-theme='dark']) .swatch-dark {
    display: none;
  }
  :global([data-theme='warm']) .swatch-warm {
    display: none;
  }
</style>

<script>
  document.querySelectorAll('[data-theme-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const next = document.documentElement.dataset.theme === 'warm' ? 'dark' : 'warm';
      document.documentElement.dataset.theme = next;
      localStorage.setItem('theme', next);
    });
  });
</script>
